# Cache static assets with long TTLs
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images
/logos/*
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=604800

/*.ico
  Cache-Control: public, max-age=604800

# Service workers must not be cached
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/pwa-sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Coinbase Smart Wallet popup (keys.coinbase.com) requires window.opener.
# Default `same-origin` COOP triggers "This app doesn't support smart wallets".
/*
  Cross-Origin-Opener-Policy: same-origin-allow-popups
